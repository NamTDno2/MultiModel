{
    "pipeline_name": "jinav4_text_zerank2_textual",
    "pipeline_alias": "jina-embeddings-v4 + zerank-2 (text)",
    "description": "Retrieves relevant documents based on textual embeddings using jinaai/jina-embeddings-v4 on text transcription and zerank2 for reranking.",
    "module_path": "pipeline_implementations/jinav4_text_zerank2textual_pipeline.py",
    "class_name": "JinaV4TextZeRank2TextualPipeline",
    "hardware_information": {
        "GPU_type": "A100-80GB",
        "num_gpus": 1,
        "num_cpu_cores": 12,
        "RAM": "128GB"
    },
    "nodes": [
        {
            "id": "retriever_node",
            "component_type": "Retriever",
            "model_name": "jinaai/jina-embeddings-v4",
            "modalities": [
                "text"
            ],
            "description": "Queries the document store and returns the top matching results."
        },
        {
            "id": "reranker_node",
            "component_type": "Reranker",
            "model_name": "zeroentropy/zerank-2",
            "modalities": [
                "text"
            ],
            "description": "Reranks the retrieved documents based on relevance to the query."
        }
    ],
    "edges": [
        {
            "source": "retriever_node",
            "target": "reranker_node",
            "description": "Passes the retrieved documents to the reranker for further processing."
        }
    ]
}